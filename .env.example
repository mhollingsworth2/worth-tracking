# ============================================================
# Worth Tracking — Environment Variable Template
# Copy this file to .env for local development.
# On Railway, set these in the service's Variables panel.
# ============================================================

# ----------------------------------------------------------
# Storage
# Path to the directory where the SQLite database is stored.
# On Railway, mount a volume at /data and set this to /data.
# ----------------------------------------------------------
DATA_DIR=/data

# ----------------------------------------------------------
# Runtime
# ----------------------------------------------------------
NODE_ENV=production
PORT=5000

# ----------------------------------------------------------
# Data Retention (archival thresholds, in days)
# Records older than these thresholds are eligible for
# archival by the nightly cron job.
# ----------------------------------------------------------
RETENTION_DAYS_SEARCH=90
RETENTION_DAYS_SNAPSHOTS=60
RETENTION_DAYS_REFERRALS=180

# ----------------------------------------------------------
# API Budget
# DAILY_BUDGET: maximum USD spend per calendar day across
#   all AI providers (OpenAI, Anthropic, Google, Perplexity).
# AUTO_PAUSE_ENABLED: set to "true" to block scans once the
#   daily budget is reached; "false" to allow overruns.
# These values are written to the database on first boot and
# can also be changed at runtime via Settings → Budget.
# ----------------------------------------------------------
DAILY_BUDGET=10.00
AUTO_PAUSE_ENABLED=true
